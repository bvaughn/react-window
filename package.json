  "homepage": "http://react-window.now.sh/",
  "repository": {
    "type": "git",
    "url": "https://github.com/bvaughn/react-window.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "pnpm run build:tsc && pnpm run build:lib && pnpm run build:docs",
    "build:docs": "pnpm run gen:docs && TARGET=docs vite build",
    "build:lib": "TARGET=lib vite build",
    "build:tsc": "tsc -b",
    "gen:docs": "node ./scripts/generate-docs.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "prepare": "husky",
    "test": "vitest"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@codemirror/lang-css": "latest",
    "@codemirror/lang-html": "latest",
    "@codemirror/lang-javascript": "latest",
    "@codemirror/lang-markdown": "latest",
    "@codemirror/language": "latest",
    "@codemirror/state": "latest",
    "@eslint/js": "^9.30.1",
    "@headlessui/react": "^2.2.4",
    "@headlessui/tailwindcss": "^0.2.2",
    "@heroicons/react": "^2.2.0",
    "@lezer/highlight": "latest",
    "@tailwindcss/vite": "^4.1.11",
    "@tailwindplus/elements": "^1.0.5",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.2.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react-swc": "^3.10.2",
    "clsx": "^2.1.1",
    "eslint": "^9.30.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.1.4",
    "prettier": "3.6.2",
    "react": "^19.1.0",
    "react-docgen-typescript": "^2.4.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.3",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.11",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.35.1",
    "typescript-json-schema": "^0.65.1",
    "vite": "^7.0.4",
