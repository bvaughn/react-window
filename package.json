{
  "name": "react-window",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm run build:tsc && pnpm run build:docs && pnpm run build:vite",
    "build:docs": "node ./scripts/generate-docs.mjs",
    "build:tsc": "tsc -b",
    "build:vite": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@codemirror/lang-css": "latest",
    "@codemirror/lang-html": "latest",
    "@codemirror/lang-javascript": "latest",
    "@codemirror/lang-markdown": "latest",
    "@codemirror/language": "latest",
    "@codemirror/state": "latest",
    "@eslint/js": "^9.30.1",
    "@lezer/highlight": "latest",
    "@tailwindcss/vite": "^4.1.11",
    "@tailwindplus/elements": "^1.0.5",
    "@types/node": "^24.2.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react-swc": "^3.10.2",
    "eslint": "^9.30.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.4",
    "prettier": "3.6.2",
    "react": "^19.1.0",
    "react-docgen-typescript": "^2.4.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.3",
    "tailwindcss": "^4.1.11",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.35.1",
    "typescript-json-schema": "^0.65.1",
    "vite": "^7.0.4",
    "vite-plugin-svgr": "^4.3.0"
  },
  "dependencies": {
    "memoize-one": "^6.0.0"
  }
